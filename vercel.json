{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/endocrine-radar",
      "schedule": "30 10 * * *"
    },
    {
      "path": "/api/cron/healthcheck",
      "schedule": "0 11 * * 1"
    },
    {
      "path": "/api/cron/podcast-refresh",
      "schedule": "0 9 * * 1"
    }
  ]
}
